# Ghostty configuration
# See docs at https://ghostty.org/docs/config

font-family = "Fira Code"
theme = "dark:Flexoki Dark,light:Flexoki Light"

# Cursor
cursor-style = block
cursor-style-blink = true
cursor-opacity = 0.8

# Quick Terminal (Quake-style dropdown)
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# Keybinds
keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Splits
unfocused-split-opacity = 0.9
keybind = cmd+shift+e=equalize_splits
keybind = cmd+shift+f=toggle_split_zoom
keybind = ctrl+left=goto_split:left
keybind = ctrl+right=goto_split:right
keybind = ctrl+up=goto_split:top
keybind = ctrl+down=goto_split:bottom
